rules_version = '2';

// ═══════════════════════════════════════════════════════
// Storage Security Rules
// Product images live at shops/{shopId}/product_images/...
// (see stock.js saveBag()). Only members of that shop may
// read or write images under their own shop's folder.
// ═══════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    function isShopMember(shopId) {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/shops/$(shopId)/users/$(request.auth.uid));
    }

    match /shops/{shopId}/product_images/{allPaths=**} {
      allow read: if isShopMember(shopId);
      allow write: if isShopMember(shopId) &&
        request.resource.size < 5 * 1024 * 1024 && // 5MB max per image
        request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
